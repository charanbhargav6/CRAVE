# CRAVE Master Configuration

# --- Core Paths ---
CRAVE_ROOT="D:\CRAVE"

# --- Master Key (Must match data/vault/master.key if used) ---
CRAVE_MASTER_KEY=your_32_byte_base64_encoded_key_here

# --- LLM API Keys ---
GEMINI_API_KEY=your_gemini_key
ANTHROPIC_API_KEY=your_claude_key
OPENAI_API_KEY=your_openai_key
GROQ_API_KEY=your_groq_key
OPENROUTER_API_KEY=your_openrouter_key

# --- Contact & Alerts ---
OWNER_EMAIL=your_email@domain.com
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- Trading API Keys (Also used by Sub_Projects/Trading) ---
BINANCE_API_KEY=your_binance_key
BINANCE_SECRET_KEY=your_binance_secret
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret

# --- Intelligence / News APIs ---
NEWS_API_KEY=your_news_api_key
GNEWS_API_KEY=your_gnews_api_key
SHODAN_API_KEY=your_shodan_key

# --- TTS/Voice ---
ELEVENLABS_API_KEY=your_elevenlabs_key
